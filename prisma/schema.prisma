generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  user
}

enum AssessmentStatus {
  pending
  in_progress
  completed
  released
  sent
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  name       String   @db.VarChar(255)
  role       UserRole @default(user)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?

  createdByUser     User?     @relation("UserCreatedBy", fields: [createdBy], references: [id])
  createdUsers      User[]    @relation("UserCreatedBy")
  sessions          UserSession[]
  assessments       Assessment[]

  @@map("users")
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("users_sessions")
}

model Assessment {
  id                  String            @id @default(cuid())
  userId              String?
  name                String            @db.VarChar(255)
  position            String            @db.VarChar(255)
  phone               String            @db.VarChar(50)
  email               String            @db.VarChar(255)
  establishmentType   String            @db.VarChar(50)
  bedCount            String            @db.VarChar(50)
  cmeProfessionals    String            @db.VarChar(50)
  region              String            @db.VarChar(50)
  state               String            @db.VarChar(50)
  consentGiven        Boolean           @default(false)
  status              AssessmentStatus  @default(pending)
  totalScore          Float?
  releasedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user       User?              @relation(fields: [userId], references: [id])
  scores     AssessmentScore[]
  responses  AssessmentResponse[]
  result     AssessmentResult?

  @@index([userId])
  @@index([status])
  @@map("assessments")
}

model AssessmentScore {
  id            String   @id @default(cuid())
  assessmentId  String
  category      String   @db.VarChar(50)
  score         Float
  maxScore      Float
  percentage    Float

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_scores")
}

model AssessmentResponse {
  id            String   @id @default(cuid())
  assessmentId  String
  questionId    String   @db.VarChar(50)
  answer        Int
  answeredAt    DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionId])
  @@index([assessmentId])
  @@map("assessment_responses")
}

model AssessmentResult {
  id                        String   @id @default(cuid())
  assessmentId              String   @unique
  managementScore           Float?
  processScore              Float?
  technologyScore           Float?
  financialScore            Float?
  lgpdScore                 Float?
  economyMinEdited          Float?
  economyMaxEdited          Float?
  financialRiskLevelEdited  String?  @db.VarChar(50)
  financialLossEdited       String?  @db.VarChar(50)
  adminObservation          String?  @db.Text
  resultJson                String?  @db.LongText
  releasedAt                DateTime?

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_results")
}